# 폐쇄망(오프라인) 환경변수 — 이 파일을 프로젝트 루트의 .env 로 복사하고 절대경로를 환경에 맞게 수정하세요.
# (경로 예시는 프로젝트를 C:\cluster_screening 에 둔 경우. 실제 설치 경로로 바꿀 것.)

# LLM 비활성(폐쇄망은 OpenAI 사용 불가)
ENABLE_LLM=0
OPENAI_API_KEY=

# HuggingFace/Transformers 완전 오프라인(네트워크 조회 차단)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# RAG 임베딩: 번들 모델 폴더의 절대경로(다운로드 대신 로컬 로드)
RAG_EMBED_MODEL=C:\cluster_screening\deploy\bundle\models\ko-sroberta

# EasyOCR: 번들 모델 폴더 + 다운로드 차단
ENABLE_OCR=1
OCR_MODEL_DIR=C:\cluster_screening\deploy\bundle\easyocr
OCR_DOWNLOAD_ENABLED=0

# unstructured가 쓰는 NLTK 데이터 경로(선택: unstructured 사용 시)
NLTK_DATA=C:\cluster_screening\deploy\bundle\nltk_data

# zip 비밀번호(필요 시)
ZIP_PASSWORD=
