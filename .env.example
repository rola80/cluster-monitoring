# 이 파일을 .env 로 복사해 값을 채우세요.  (.env 는 git에 올라가지 않음)
#   cp .env.example .env   /   PowerShell:  Copy-Item .env.example .env

# OpenAI — RAG 임베딩(text-embedding-3-small)에 사용. 없으면 임베딩은 offline 모드로 폴백.
OPENAI_API_KEY=

# RAG 임베딩 제공자: openai | offline
RAG_EMBED_PROVIDER=openai
# 판정에 근거 조항 첨부 + 노이즈 필터(이 미만 유사도면 미첨부)
ENABLE_RAG_BASIS=1
RAG_MIN_SCORE=0.3

# OCR(스캔 PDF) — 앞 N페이지만, 해상도
ENABLE_OCR=1
OCR_DPI=200
OCR_MAX_PAGES=8

# 추출 캐시·병렬(속도)
ENABLE_EXTRACT_CACHE=1
EXTRACT_WORKERS=4

# 구비서류 zip 비밀번호(필요 시 — UI/CLI에서도 입력 가능, 코드 하드코딩 금지)
ZIP_PASSWORD=
