# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요.  (.env 는 git에 올라가지 않음)
# cp .env.example .env   /   PowerShell:  Copy-Item .env.example .env

# OpenAI (LLM 필드추출 폴백). 키가 있으면 자동으로 LLM이 켜진다.
OPENAI_API_KEY=sk-여기에-실제키-입력
LLM_MODEL=gpt-4.1-mini
LLM_MODEL_VISION=gpt-4.1

# OCR
ENABLE_OCR=1
OCR_LANG=kor+eng
OCR_DPI=300

# 구비서류 zip 비밀번호(있으면)
ZIP_PASSWORD=
